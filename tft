name: safeher-ai
channels:
  - pytorch
  - conda-forge
  - defaults

dependencies:
  - python=3.10

  # Core
  - numpy
  - pandas
  - scikit-learn

  # PyTorch
  - pytorch
  - torchvision
  - torchaudio
  - cpuonly   # remove if using GPU

  # API
  - fastapi
  - uvicorn

  # Utils
  - joblib

  # Pip (for optional packages)
  - pip
  - pip:
      - python-dotenv